{
  "type": "object",
  "additionalProperties": false,
  "required": ["screen_id", "user_goal", "task_type", "system", "research_sources", "sections", "gaps", "validation_checks", "generation_boundary"],
  "properties": {
    "screen_id": { "type": "string", "minLength": 1 },
    "user_goal": { "type": "string", "minLength": 1 },
    "task_type": { "type": "string", "minLength": 1 },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "system": { "type": "string", "minLength": 1 },
    "research_sources": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "pattern", "components", "requirements", "findings", "rationale"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "pattern": { "type": "string", "minLength": 1 },
          "components": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "requirements": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "findings": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "issue", "impact"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["blocking", "major", "minor"]
          },
          "issue": { "type": "string", "minLength": 1 },
          "impact": { "type": "string", "minLength": 1 }
        }
      }
    },
    "validation_checks": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "generation_boundary": { "type": "string", "minLength": 1 }
  }
}
