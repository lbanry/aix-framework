{
  "name": "aix-framework",
  "version": "0.2.0",
  "description": "A system-agnostic AI Experience Framework for improving human-AI collaboration.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lbanry/aix-framework.git"
  },
  "keywords": [
    "ai",
    "prompting",
    "contracts",
    "cli",
    "validation"
  ],
  "workspaces": [
    "packages/aix-core",
    "packages/aix-design"
  ],
  "files": [
    "src",
    "packages",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "aix": "./src/cli.js"
  },
  "scripts": {
    "aix": "node ./src/cli.js",
    "test": "node ./tests/smoke-test.mjs",
    "test:project": "node ./src/cli.js run packages/aix-core/examples/project-contract.yaml",
    "prompt:project": "node ./src/cli.js prompt packages/aix-core/examples/project-contract.yaml",
    "inspect:project": "node ./src/cli.js inspect packages/aix-core/examples/project-contract.yaml",
    "inspect:research": "node ./src/cli.js inspect packages/aix-core/examples/research-contract.yaml",
    "prompt:research": "node ./src/cli.js prompt packages/aix-core/examples/research-contract.yaml"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "commander": "^14.0.3",
    "yaml": "^2.8.3"
  }
}
