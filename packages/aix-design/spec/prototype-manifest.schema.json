{
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "screen_id", "source_plan", "source_system", "output", "tokens", "patterns", "sections", "validation_rules"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "screen_id": { "type": "string", "minLength": 1 },
    "source_plan": { "type": "string", "minLength": 1 },
    "source_system": { "type": "string", "minLength": 1 },
    "design_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "imported_at": { "type": "string", "minLength": 1 }
      }
    },
    "design_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "philosophy": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "brand_personality": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "content_tone": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "interaction_rules": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "motion_rules": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "generation_constraints": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "examples": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "entrypoint"],
      "properties": {
        "format": { "type": "string", "enum": ["static_html"] },
        "entrypoint": { "type": "string", "minLength": 1 }
      }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": ["color", "spacing"],
      "properties": {
        "color": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "spacing": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "typography": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "minLength": 1 }
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "pattern", "components", "requirements"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "pattern": { "type": "string", "minLength": 1 },
          "components": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "requirements": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "render": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["component"],
              "properties": {
                "component": { "type": "string", "minLength": 1 },
                "element": { "type": "string", "minLength": 1 },
                "role": { "type": "string", "minLength": 1 },
                "variant": { "type": "string", "minLength": 1 },
                "layout": { "type": "string", "minLength": 1 },
                "emphasis": { "type": "string", "minLength": 1 },
                "label_style": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "validation_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
