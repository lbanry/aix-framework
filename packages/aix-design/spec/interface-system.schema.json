{
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "version", "tokens", "components", "patterns", "accessibility_rules"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["design-md", "manual"]
        },
        "path": { "type": "string", "minLength": 1 },
        "imported_at": { "type": "string", "minLength": 1 }
      }
    },
    "philosophy": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "brand_personality": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "content_tone": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "interaction_rules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "motion_rules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "generation_constraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "examples": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": ["color", "spacing"],
      "properties": {
        "color": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "spacing": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "typography": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "purpose", "supports", "rules"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "supports": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "states": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "render": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "element": { "type": "string", "minLength": 1 },
              "role": { "type": "string", "minLength": 1 },
              "variant": { "type": "string", "minLength": 1 },
              "layout": { "type": "string", "minLength": 1 },
              "emphasis": {
                "type": "string",
                "enum": ["primary", "secondary", "subtle", "status", "data", "input"]
              },
              "label_style": { "type": "string", "minLength": 1 },
              "states": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          },
          "rules": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "purpose", "use_when", "required_components", "information_order", "rules"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "use_when": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "required_components": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "information_order": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "rules": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "avoid_when": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "accessibility_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
